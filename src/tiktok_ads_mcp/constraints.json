    "audience_dimension_filtering": {
      "_description": "AUDIENCE report dimension filters are SILENTLY IGNORED by the API — it returns code 0 but does not filter rows.",
      "gender": {"accepted": true, "actually_filters": false, "enum_values": ["GENDER_MALE", "GENDER_FEMALE"]},
      "age": {"accepted": true, "actually_filters": false, "enum_values": ["AGE_13_17", "AGE_18_24", "AGE_25_34", "AGE_35_44", "AGE_45_54", "AGE_55_100"]},
      "country_code": {"accepted": false, "error": "country_code is not supported as a filter field"},
